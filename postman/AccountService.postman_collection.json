{
  "info": {
    "_postman_id": "6dd1109c-a9b1-4d3b-99a2-b7b6ec8f4e41",
    "name": "Account Service",
    "description": "Postman collection for account-service endpoints secured with Keycloak. Run the token request first to populate {{access_token}}, then call the secured endpoints. Defaults are configured for the Keycloak master realm using the built-in admin-cli client.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8081"
    },
    {
      "key": "keycloak_base_url",
      "value": "http://localhost:8084"
    },
    {
      "key": "realm",
      "value": "master"
    },
    {
      "key": "client_id",
      "value": "admin-cli"
    },
    {
      "key": "username",
      "value": "admin"
    },
    {
      "key": "password",
      "value": "admin"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "account_id",
      "value": "11111111-1111-1111-1111-111111111111"
    },
    {
      "key": "transaction_id",
      "value": "22222222-2222-2222-2222-222222222222"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Keycloak Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.access_token) {",
                  "    pm.collectionVariables.set('access_token', json.access_token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "password",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}",
                  "type": "text"
                },
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{keycloak_base_url}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": [
                "{{keycloak_base_url}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                "protocol",
                "openid-connect",
                "token"
              ]
            },
            "description": "Fetches an access token from Keycloak and stores it in {{access_token}}. This assumes the client allows direct access grants and the user exists in realm {{realm}}."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "Open Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"type\": \"CURRENT\",\n  \"initialBalance\": 1000.00,\n  \"currency\": \"EUR\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/accounts/open",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "open"
              ]
            },
            "description": "Creates a new account. The endpoint is permitAll in Spring Security, but the collection still carries bearer auth at collection level."
          },
          "response": []
        },
        {
          "name": "Get Account By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/accounts/{{account_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "{{account_id}}"
              ]
            },
            "description": "Requires role USER or ADMIN."
          },
          "response": []
        },
        {
          "name": "Debit Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{transaction_id}}\",\n  \"amount\": 50.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/accounts/{{account_id}}/debit",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "{{account_id}}",
                "debit"
              ]
            },
            "description": "Requires ADMIN role, or a token whose authentication.name equals the account_id string."
          },
          "response": []
        },
        {
          "name": "Update Account Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"BLOCKED\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/accounts/{{account_id}}/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "{{account_id}}",
                "status"
              ]
            },
            "description": "Requires ADMIN role."
          },
          "response": []
        },
        {
          "name": "Close Account",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/v1/accounts/{{account_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "{{account_id}}"
              ]
            },
            "description": "Requires ADMIN role. Internally transitions the account to CLOSED."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Get All Accounts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/accounts/search?page=0&size=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "search"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "Requires authentication because any unmatched request in the current security config falls through to authenticated()."
          },
          "response": []
        }
      ]
    }
  ]
}
